generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Dish {
  id             String   @id @default(cuid())
  name           String
  category       String
  imageUrl       String?  @db.LongText
  spiceLevel     Int      @default(0)
  sweetnessLevel Int      @default(0)
  difficulty     String   @default("medium")
  prepTime       Int?
  ingredients    String?  @db.Text
  ingredientDetails String? @db.LongText
  tags           String?  @db.Text
  chefNote       String?  @db.Text
  description    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comboDishes    ComboDish[]
  mealDishes     MealDish[]
}

model Combo {
  id         String      @id @default(cuid())
  name       String
  isFavorite Boolean     @default(false)
  createdAt  DateTime    @default(now())
  comboDishes ComboDish[]
  meals      MealRecord[]
}

model ComboDish {
  id      String @id @default(cuid())
  comboId String
  dishId  String
  combo   Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  dish    Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([comboId, dishId])
}

model Chef {
  id        String       @id @default(cuid())
  name      String       @unique
  avatar    String?      @db.LongText
  createdAt DateTime     @default(now())
  meals     MealRecord[]
}

model MealRecord {
  id              String     @id @default(cuid())
  date            String
  mealType        String     @default("lunch")
  mealTime        String?
  chefName        String?    @map("chef")
  chefId          String?
  personCount     Int        @default(2)
  orderStatus     String     @default("pending")
  feedbackRating  Int?
  feedbackComment String?    @db.Text
  feedbackImages  String?    @db.LongText
  note            String?    @db.Text
  comboId         String?
  createdAt       DateTime   @default(now())
  chef            Chef?      @relation(fields: [chefId], references: [id], onDelete: SetNull)
  combo           Combo?     @relation(fields: [comboId], references: [id], onDelete: SetNull)
  mealDishes      MealDish[]

  @@index([chefId])
}

model MealDish {
  id           String     @id @default(cuid())
  mealRecordId String
  dishId       String
  quantity     Int        @default(1)
  note         String?    @db.Text
  mealRecord   MealRecord @relation(fields: [mealRecordId], references: [id], onDelete: Cascade)
  dish         Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([mealRecordId, dishId])
}
